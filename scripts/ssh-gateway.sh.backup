#!/bin/bash

# SSH Gateway for Multi-User Docker Containers
# Simplified version based on working setup

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

USERS_DB="/var/lib/user-containers/users.db"
SSHD_CONFIG="/etc/ssh/sshd_config"

# ============================
# HELP
# ============================
show_help() {
    echo -e "${BLUE}SSH Gateway for Container Access${NC}"
    echo ""
    echo "Usage: $0 [command]"
    echo ""
    echo "Commands:"
    echo "  setup           - Setup SSH gateway (one time)"
    echo "  add-key <user>  - Add SSH public key for user"
    echo "  remove-key <user> - Remove user's SSH access"
    echo "  list            - List all SSH users"
    echo "  test <user>     - Test user's SSH configuration"
    echo ""
    echo "After setup, users connect via:"
    echo "  ssh -p 2222 username@server-ip"
    echo "  ssh username@ssh.yourdomain.com -o ProxyCommand=\"cloudflared access ssh --hostname %h\""
    echo ""
}

# ============================
# SETUP SSH GATEWAY
# ============================
setup_gateway() {
    echo -e "${YELLOW}Setting up SSH gateway...${NC}"
    echo ""
    
    # Check if running as root
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}Error: Must run as root${NC}"
        exit 1
    fi
    
    # Install OpenSSH if needed
    if ! command -v sshd &> /dev/null; then
        echo "Installing OpenSSH server..."
        if [ -f /etc/debian_version ]; then
            apt-get update && apt-get install -y openssh-server
        elif [ -f /etc/redhat-release ]; then
            yum install -y openssh-server
        else
            echo -e "${RED}Error: Unsupported OS${NC}"
            exit 1
        fi
    fi
    
    # Backup sshd_config if not already backed up
    if [ ! -f "${SSHD_CONFIG}.backup" ]; then
        cp "$SSHD_CONFIG" "${SSHD_CONFIG}.backup"
        echo "✓ Backed up SSH config"
    fi
    
    # Configure SSH on port 2222
    if ! grep -q "^Port 2222" "$SSHD_CONFIG"; then
        echo "" >> "$SSHD_CONFIG"
        echo "# Container Gateway Configuration" >> "$SSHD_CONFIG"
        echo "Port 2222" >> "$SSHD_CONFIG"
        echo "PasswordAuthentication no" >> "$SSHD_CONFIG"
        echo "PubkeyAuthentication yes" >> "$SSHD_CONFIG"
        echo "PermitRootLogin no" >> "$SSHD_CONFIG"
        echo "✓ Configured SSH on port 2222"
    fi
    
    # Test SSH config
    if ! sshd -t; then
        echo -e "${RED}Error: Invalid SSH configuration${NC}"
        exit 1
    fi
    
    # Restart SSH
    systemctl restart sshd || systemctl restart ssh
    echo "✓ SSH service restarted"
    
    # Create log directory
    mkdir -p /var/lib/user-containers/logs
    
    echo ""
    echo -e "${GREEN}✓ SSH gateway setup complete${NC}"
    echo ""
    echo "Next steps:"
    echo "1. Create users: sudo ./multi-user-containers.sh create-user <username>"
    echo "2. Add SSH keys: sudo $0 add-key <username>"
    echo "3. Users connect: ssh -p 2222 username@server-ip"
    echo ""
}

# ============================
# ADD SSH KEY
# ============================
add_ssh_key() {
    USERNAME="$1"
    
    if [ -z "$USERNAME" ]; then
        echo -e "${RED}Error: Username required${NC}"
        echo "Usage: $0 add-key <username>"
        exit 1
    fi
    
    # Check if user exists in database
    if ! grep -q "^$USERNAME:" "$USERS_DB" 2>/dev/null; then
        echo -e "${RED}Error: User '$USERNAME' not found${NC}"
        echo "Create user first: sudo ./multi-user-containers.sh create-user $USERNAME"
        exit 1
    fi
    
    # Get container name
    USER_DATA=$(grep "^$USERNAME:" "$USERS_DB")
    CONTAINER=$(echo "$USER_DATA" | cut -d: -f2)
    
    # Check if Linux user exists
    if ! id "$USERNAME" &>/dev/null; then
        echo "Creating Linux user: $USERNAME"
        useradd -m -s /bin/bash "$USERNAME"
    fi
    
    # Add user to docker group
    usermod -aG docker "$USERNAME"
    echo "✓ Added $USERNAME to docker group"
    
    # Create .ssh directory
    mkdir -p "/home/$USERNAME/.ssh"
    touch "/home/$USERNAME/.ssh/authorized_keys"
    chmod 700 "/home/$USERNAME/.ssh"
    chmod 600 "/home/$USERNAME/.ssh/authorized_keys"
    chown -R "$USERNAME:$USERNAME" "/home/$USERNAME/.ssh"
    
    # Get SSH public key
    echo ""
    echo -e "${YELLOW}Paste the user's SSH public key (from ~/.ssh/id_rsa.pub or ~/.ssh/id_ed25519.pub)${NC}"
    echo "Press Enter when done:"
    echo ""
    
    read -r SSH_KEY
    
    if [ -z "$SSH_KEY" ]; then
        echo -e "${RED}Error: No key provided${NC}"
        exit 1
    fi
    
    # Add key to authorized_keys
    echo "$SSH_KEY" >> "/home/$USERNAME/.ssh/authorized_keys"
    echo "✓ Added SSH key"
    
    # Add ForceCommand to sshd_config
    if ! grep -q "Match User $USERNAME" "$SSHD_CONFIG"; then
        cat >> "$SSHD_CONFIG" << SSHEOF

# Container access for $USERNAME
Match User $USERNAME
    ForceCommand docker exec -it $CONTAINER /bin/bash
    PermitTTY yes
SSHEOF
        echo "✓ Configured SSH ForceCommand"
    else
        echo "⚠️  SSH configuration already exists for $USERNAME"
    fi
    
    # Restart SSH
    systemctl restart sshd || systemctl restart ssh
    echo "✓ SSH service restarted"
    
    # Log access setup
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] SSH key added: $USERNAME" >> /var/lib/user-containers/logs/access.log
    
    echo ""
    echo -e "${GREEN}✓ SSH access configured for $USERNAME${NC}"
    echo ""
    echo "User can now connect:"
    echo "  ssh -p 2222 $USERNAME@$(hostname -I | awk '{print $1}' 2>/dev/null || echo 'your-server-ip')"
    echo ""
    echo "Via Cloudflare Tunnel:"
    echo "  ssh $USERNAME@ssh.yourdomain.com -o ProxyCommand=\"cloudflared access ssh --hostname %h\""
    echo ""
}

# ============================
# REMOVE SSH KEY
# ============================
remove_ssh_key() {
    USERNAME="$1"
    
    if [ -z "$USERNAME" ]; then
        echo -e "${RED}Error: Username required${NC}"
        echo "Usage: $0 remove-key <username>"
        exit 1
    fi
    
    # Remove user's SSH keys
    if [ -d "/home/$USERNAME/.ssh" ]; then
        rm -rf "/home/$USERNAME/.ssh"
        echo "✓ Removed SSH keys"
    fi
    
    # Remove from sshd_config
    if grep -q "Match User $USERNAME" "$SSHD_CONFIG"; then
        # Remove the Match User block (3 lines)
        sed -i "/# Container access for $USERNAME/,+3d" "$SSHD_CONFIG"
        echo "✓ Removed SSH configuration"
        
        # Restart SSH
        systemctl restart sshd || systemctl restart ssh
        echo "✓ SSH service restarted"
    fi
    
    # Log removal
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] SSH key removed: $USERNAME" >> /var/lib/user-containers/logs/access.log
    
    echo ""
    echo -e "${GREEN}✓ SSH access removed for $USERNAME${NC}"
    echo ""
}

# ============================
# LIST SSH USERS
# ============================
list_ssh_users() {
    echo -e "${BLUE}=== SSH Users ===${NC}"
    echo ""
    
    if [ ! -f "$USERS_DB" ]; then
        echo "No users found"
        return 0
    fi
    
    printf "%-15s %-30s %-10s\n" "USERNAME" "CONTAINER" "SSH KEY"
    echo "─────────────────────────────────────────────────────────────"
    
    while IFS=: read -r username container _; do
        if [ -f "/home/$username/.ssh/authorized_keys" ]; then
            KEY_STATUS="✓ Yes"
        else
            KEY_STATUS="✗ No"
        fi
        printf "%-15s %-30s %-10s\n" "$username" "$container" "$KEY_STATUS"
    done < "$USERS_DB"
    echo ""
}

# ============================
# TEST SSH CONFIG
# ============================
test_ssh_config() {
    USERNAME="$1"
    
    if [ -z "$USERNAME" ]; then
        echo -e "${RED}Error: Username required${NC}"
        echo "Usage: $0 test <username>"
        exit 1
    fi
    
    echo -e "${YELLOW}Testing SSH configuration for $USERNAME...${NC}"
    echo ""
    
    # Check user exists
    if ! grep -q "^$USERNAME:" "$USERS_DB" 2>/dev/null; then
        echo -e "${RED}✗ User not found in database${NC}"
        exit 1
    else
        echo -e "${GREEN}✓ User exists in database${NC}"
    fi
    
    # Get container
    USER_DATA=$(grep "^$USERNAME:" "$USERS_DB")
    CONTAINER=$(echo "$USER_DATA" | cut -d: -f2)
    
    # Check Linux user
    if id "$USERNAME" &>/dev/null; then
        echo -e "${GREEN}✓ Linux user exists${NC}"
    else
        echo -e "${RED}✗ Linux user does not exist${NC}"
    fi
    
    # Check docker group
    if groups "$USERNAME" 2>/dev/null | grep -q docker; then
        echo -e "${GREEN}✓ User in docker group${NC}"
    else
        echo -e "${RED}✗ User not in docker group${NC}"
    fi
    
    # Check SSH directory
    if [ -d "/home/$USERNAME/.ssh" ]; then
        echo -e "${GREEN}✓ SSH directory exists${NC}"
    else
        echo -e "${RED}✗ SSH directory missing${NC}"
    fi
    
    # Check authorized_keys
    if [ -f "/home/$USERNAME/.ssh/authorized_keys" ]; then
        KEY_COUNT=$(wc -l < "/home/$USERNAME/.ssh/authorized_keys")
        echo -e "${GREEN}✓ SSH keys configured ($KEY_COUNT keys)${NC}"
    else
        echo -e "${RED}✗ No SSH keys configured${NC}"
    fi
    
    # Check container
    if docker ps --format '{{.Names}}' | grep -q "^$CONTAINER$"; then
        echo -e "${GREEN}✓ Container is running${NC}"
    else
        echo -e "${RED}✗ Container not running${NC}"
    fi
    
    # Check sshd_config
    if grep -q "Match User $USERNAME" "$SSHD_CONFIG"; then
        echo -e "${GREEN}✓ SSH ForceCommand configured${NC}"
    else
        echo -e "${RED}✗ SSH ForceCommand not configured${NC}"
    fi
    
    echo ""
    echo "Test command:"
    echo "  ssh -p 2222 $USERNAME@$(hostname -I | awk '{print $1}' 2>/dev/null || echo 'server-ip')"
    echo ""
}

# ============================
# MAIN
# ============================
case "${1:-}" in
    setup)
        setup_gateway
        ;;
    add-key)
        add_ssh_key "$2"
        ;;
    remove-key)
        remove_ssh_key "$2"
        ;;
    list)
        list_ssh_users
        ;;
    test)
        test_ssh_config "$2"
        ;;
    *)
        show_help
        ;;
esac
